{
  "$schema": "../repo-agent-management.schema.json#/$defs/repository",
  "slug": "example",
  "display_name": "Example Code App",
  "registry_path": "/path/to/your/repo",
  "profile_slug": "example",
  "repository_type": "code_app",
  "rollout_class": "immediate_migrate",
  "overlay_archetype": "code_app",
  "status": "active",
  "management_template_id": "code_app",
  "management_mode": "harness-managed",
  "profile_source": {
    "kind": "example-profile",
    "path": "docs/examples/repositories/example/repo-profile.toml"
  },
  "managed_domains": [
    "central_ownership_contract",
    "repository_overlay",
    "generation_verification_pipeline",
    "operating_contract",
    "harness_structure",
    "harness_format",
    "agent_management"
  ],
  "fleet_management": {
    "active_target": true,
    "control_repo": false,
    "runtime_contract_exception": false,
    "diet_mode": "normal"
  },
  "exception_review": {
    "requires_repo_specific_runtime_review": false,
    "protected_categories": []
  },
  "evidence_trace": {
    "source_documents": [
      "docs/examples/repositories/example/repo-profile.toml"
    ],
    "open_questions": [],
    "assumptions": [
      "Standard code_app template is sufficient for this repo."
    ]
  },
  "notes": [
    "Copy this file and rename for your repo, edit slug + display_name + registry_path.",
    "This example ships with all 12 catalog agents and 11 catalog skills active by default (matches the template-wide policy). Trim the lists below if a specific repo does not need a specialist or skill — empty 'skill_overrides.add' / 'agent_overrides.add_specialists' mean no additions beyond active_*."
  ],
  "active_agents": [
    "main-orchestrator",
    "executor-agent",
    "codex-final-reviewer",
    "quality-agent",
    "fleet-doc-steward",
    "cwe-auditor",
    "dep-auditor",
    "ui-reviewer",
    "pipeline-validator",
    "ontology-validator",
    "runtime-contract-reviewer",
    "template-sync-validator"
  ],
  "active_skills": [
    "design",
    "verify",
    "code-review",
    "testing",
    "ui-design",
    "governance",
    "knowledge",
    "automation",
    "efficiency",
    "bluebricks",
    "commit"
  ],
  "agent_overrides": {
    "add_specialists": [],
    "remove_specialists": []
  },
  "skill_overrides": {
    "add": [],
    "remove": []
  },
  "orchestration_profile": "standard"
}
