{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^(Bash|apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-tool-use.sh",
            "timeout": 30,
            "statusMessage": "Mir L2 PreToolUse"
          }
        ]
      },
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-merge-gate.sh",
            "timeout": 30,
            "statusMessage": "Mir pre-merge gate"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Bash|apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-edit-check.sh",
            "timeout": 30,
            "statusMessage": "Mir post-edit check"
          },
          {
            "type": "command",
            "command": ".claude/hooks/post-edit-self-ingest.sh",
            "timeout": 30,
            "statusMessage": "ADR-05 self-ingest"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "^(Bash|apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-tool-use.sh",
            "timeout": 30,
            "statusMessage": "Mir L2 PermissionRequest"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-start.sh",
            "timeout": 30,
            "statusMessage": "Mir session-start"
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/tdd-task-created.sh",
            "timeout": 30,
            "statusMessage": "Mir TDD guard (task creation gate)"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/tdd-task-completed.sh",
            "timeout": 30,
            "statusMessage": "Mir TDD completion gate"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/mir-stop.sh",
            "timeout": 30,
            "statusMessage": "Mir Stop audit"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/stop-failure-audit.sh",
            "timeout": 30,
            "statusMessage": "Mir StopFailure audit"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-compact.sh",
            "timeout": 60,
            "statusMessage": "Mir PreCompact checkpoint"
          }
        ]
      }
    ]
  }
}
